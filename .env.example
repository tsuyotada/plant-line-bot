# ── Supabase ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ── App ────────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
DEFAULT_HOUSEHOLD_ID=
ADMIN_EMAILS=

# ── OpenAI ─────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=

# ── LINE Bot (Messaging API channel) ──────────────────────────────────────────
# Separate from LINE Login channel. Used for bot push/reply messages.
LINE_CHANNEL_ACCESS_TOKEN=
NEXT_PUBLIC_LINE_ADD_FRIEND_URL=https://line.me/R/ti/p/@YOUR_BOT_ID

# ── LINE Login (OAuth channel) ────────────────────────────────────────────────
# Create a NEW "LINE Login" channel in LINE Developers Console.
# This is SEPARATE from the Messaging API / Official Account channel.
#
# Steps:
#   1. https://developers.line.biz/ → Create provider (if none) → Add channel → LINE Login
#   2. Channel ID   → LINE_LOGIN_CHANNEL_ID
#   3. Channel Secret → LINE_LOGIN_CHANNEL_SECRET
#   4. Register Callback URL in: LINE Login channel → Callback URL
#      Local:      http://localhost:3000/api/auth/line/callback
#      Production: https://your-app.vercel.app/api/auth/line/callback
LINE_LOGIN_CHANNEL_ID=
LINE_LOGIN_CHANNEL_SECRET=
LINE_LOGIN_CALLBACK_URL=https://your-app.vercel.app/api/auth/line/callback

# Secret used to derive per-user passwords for Supabase accounts created via LINE Login.
# Generate with: openssl rand -hex 32
# Must be kept secret and stable (changing it invalidates all LINE Login sessions).
LINE_SESSION_SECRET=
